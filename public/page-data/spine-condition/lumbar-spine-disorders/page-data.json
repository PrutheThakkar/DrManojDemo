{"componentChunkName":"component---src-templates-spine-condition-listing-js","path":"/spine-condition/lumbar-spine-disorders/","result":{"data":{"wpSpineCondition":{"title":"Lumbar Spine Disorders","slug":"lumbar-spine-disorders","content":"<p>Lumbar spine disorders affect the lower back and are commonly caused by degeneration, instability, or disc-related problems. These conditions may lead to persistent lower back pain, stiffness, or pain radiating into the legs. Daily activities such as bending, lifting, or prolonged standing may become difficult. Symptoms can gradually worsen over time without proper management.</p>\n","featuredImage":null,"spineConditionsPost":{"desciption":" <div className=\"section-title-wrp\">\r\n            <h2>Treatments & Procedures</h2>\r\n            <p className=\"treatments-intro\">\r\n              Lower back conditions involving degeneration, instability, or chronic pain.\r\n            </p>\r\n            </div>"}},"allWpSpineCondition":{"nodes":[{"title":"Slipped or Herniated Disc","slug":"slipped-or-herniated-disc","databaseId":130,"menuOrder":1},{"title":"Sciatica & Nerve Compression","slug":"sciatica-nerve-compression","databaseId":157,"menuOrder":2},{"title":"Cervical Spine Disorders","slug":"cervical-spine-disorders","databaseId":158,"menuOrder":3},{"title":"Lumbar Spine Disorders","slug":"lumbar-spine-disorders","databaseId":159,"menuOrder":4},{"title":"Spinal Stenosis","slug":"spinal-stenosis","databaseId":160,"menuOrder":5},{"title":"Scoliosis & Spine Deformities","slug":"scoliosis-spine-deformities","databaseId":161,"menuOrder":6},{"title":"Spine Trauma & Fractures","slug":"spine-trauma-fractures","databaseId":162,"menuOrder":7},{"title":"Osteoporotic Compression Fractures","slug":"osteoporotic-compression-fractures","databaseId":163,"menuOrder":8},{"title":"Craniovertebral Junction Disorders","slug":"craniovertebral-junction-disorders","databaseId":164,"menuOrder":9},{"title":"Spinal Infections & Tuberculosis","slug":"sp